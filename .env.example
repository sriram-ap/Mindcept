# ── Site ────────────────────────────────────────────────────────────────
# Canonical production URL (no trailing slash). Used for metadata, sitemap,
# robots.txt and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://mindceptconsulting.com

# ── Lead capture (post-launch integrations) ─────────────────────────────
# Where /api/enquiry forwards submissions. Leave empty to log-only.
# e.g. a Google Apps Script / Zapier / CRM webhook URL.
LEAD_WEBHOOK_URL=

# ── Analytics & marketing (post-launch; see POST_LAUNCH_BACKLOG.md) ─────
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ── AI search (post-launch; see src/lib/ai/) ────────────────────────────
OPENAI_API_KEY=
