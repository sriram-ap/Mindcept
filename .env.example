# ── Site ────────────────────────────────────────────────────────────────
# Canonical production URL (no trailing slash). Used for metadata, sitemap,
# robots.txt and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://mindceptconsulting.com

# ── Lead capture (post-launch integrations) ─────────────────────────────
# Where /api/enquiry forwards submissions. Leave empty to log-only.
# e.g. a Google Apps Script / Zapier / CRM webhook URL.
LEAD_WEBHOOK_URL=

# ── Analytics & marketing (post-launch; see POST_LAUNCH_BACKLOG.md) ─────
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ── Database (see docs/DATABASE_ARCHITECTURE.md) ────────────────────────
# Unset            → typed content modules (default, zero infrastructure)
# mongodb://localhost:27017          → MongoDB Community (local)
# mongodb+srv://…mongodb.net         → MongoDB Atlas (production)
MONGODB_URI=
MONGODB_DB=mindcept

# ── Asset storage — Cloudflare R2 (see docs/IMAGE_STORAGE_ARCHITECTURE.md)
# Public bucket / custom domain base URL, e.g. https://assets.mindceptconsulting.com
NEXT_PUBLIC_R2_PUBLIC_URL=
# Upload credentials (Admin CMS only — never exposed to the browser)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mindcept-assets

# ── Feature flags (production exposes only finished features) ───────────
# Set BOTH properties vars to the same value; the NEXT_PUBLIC_ one drives nav links.
ENABLE_PROPERTIES=
NEXT_PUBLIC_ENABLE_PROPERTIES=
ENABLE_AI_SEARCH=
ENABLE_REPORTS=
ENABLE_ADMIN=

# ── AI search (post-launch; see src/lib/ai/) ────────────────────────────
OPENAI_API_KEY=
